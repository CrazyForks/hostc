{
	"name": "hostc-workspace",
	"private": true,
	"version": "0.0.0",
	"packageManager": "pnpm@10.33.0",
	"scripts": {
		"dev": "pnpm -r --parallel --if-present dev",
		"dev:server": "pnpm -F @hostc/server dev",
		"build": "pnpm -F @hostc/protocol build && pnpm -F @hostc/server build && pnpm -F hostc build",
		"build:cli": "pnpm -F hostc build",
		"deploy:server": "pnpm -F @hostc/server deploy",
		"deploy:server:staging": "pnpm -F @hostc/server deploy:staging",
		"test": "pnpm -F @hostc/protocol test && pnpm -F @hostc/server test && pnpm -F hostc test",
		"test:e2e:local": "pnpm -F @hostc/server test:e2e:local",
		"test:stress:local": "pnpm -F @hostc/protocol stress:local",
		"test:e2e:staging": "pnpm -F @hostc/server test:e2e:staging",
		"load:staging": "pnpm -F @hostc/server load:staging",
		"preflight:staging": "pnpm -F @hostc/server preflight:staging",
		"audit:refactor": "node scripts/audit-refactor.mjs",
		"cleanup:legacy": "node scripts/cleanup-legacy.mjs",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write ."
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.12"
	}
}
