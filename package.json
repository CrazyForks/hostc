{
	"name": "hostc-workspace",
	"private": true,
	"version": "0.0.0",
	"packageManager": "pnpm@10.33.0",
	"scripts": {
		"dev": "pnpm -F @hostc/web dev",
		"dev:server": "pnpm -F @hostc/server dev",
		"build": "pnpm build:protocol && pnpm build:client && pnpm build:server && pnpm build:cli",
		"build:cli": "pnpm -F hostc build",
		"deploy:server": "pnpm -F @hostc/server deploy",
		"deploy:server:staging": "pnpm -F @hostc/server deploy:staging",
		"test": "pnpm test:unit",
		"test:e2e:local": "pnpm -F @hostc/server test:e2e:local",
		"test:stress:local": "pnpm stress:local",
		"test:e2e:staging": "pnpm -F @hostc/server test:e2e:staging",
		"load:staging": "pnpm stress:remote",
		"preflight:staging": "pnpm -F @hostc/server preflight:staging",
		"audit:refactor": "node scripts/audit-refactor.mjs",
		"cleanup:legacy": "node scripts/cleanup-legacy.mjs",
		"lint": "biome check .",
		"lint:fix": "biome check . --write",
		"format": "biome format . --write",
		"build:protocol": "pnpm -F @hostc/protocol build",
		"build:client": "pnpm -F @hostc/client build",
		"build:server": "pnpm -F @hostc/server build",
		"test:unit": "pnpm -F @hostc/protocol test && pnpm -F @hostc/client test && pnpm -F @hostc/server test && pnpm -F hostc test",
		"test:integration": "pnpm -F @hostc/client test && pnpm -F @hostc/server test",
		"test:e2e:remote": "pnpm test:e2e:staging",
		"bench:protocol": "pnpm -F @hostc/protocol bench",
		"bench:local": "pnpm build && node scripts/bench-local.mjs",
		"bench:remote": "pnpm build && node scripts/bench-remote.mjs",
		"stress:protocol": "pnpm -F @hostc/protocol stress:local",
		"stress:local": "pnpm build && node scripts/stress-local.mjs",
		"stress:remote": "pnpm build && node scripts/stress-remote.mjs",
		"verify:local": "pnpm build && pnpm lint && pnpm test && pnpm bench:local && pnpm stress:local",
		"verify:staging": "pnpm staging:verify",
		"staging:deploy": "pnpm deploy:server:staging",
		"staging:secret": "pnpm -F @hostc/server secret:staging",
		"staging:preflight": "pnpm preflight:staging",
		"staging:test": "HOSTC_SERVER_URL=https://envoq.dev pnpm test:e2e:staging && HOSTC_SERVER_URL=https://envoq.dev pnpm bench:remote && HOSTC_SERVER_URL=https://envoq.dev pnpm stress:remote",
		"staging:verify": "pnpm staging:deploy && pnpm staging:preflight && pnpm staging:test",
		"staging:deploy:secrets": "pnpm -F @hostc/server deploy:staging:secrets",
		"staging:init": "pnpm staging:deploy:secrets && pnpm staging:preflight",
		"test:e2e:cli": "pnpm build && node scripts/e2e-cli.mjs"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.12"
	}
}
