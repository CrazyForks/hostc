{
	"name": "@hostc/client",
	"version": "1.3.0",
	"description": "Embeddable hostc tunnel client SDK.",
	"type": "module",
	"license": "Apache-2.0",
	"sideEffects": false,
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"README.md"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/akazwz/hostc.git",
		"directory": "packages/client"
	},
	"bugs": {
		"url": "https://github.com/akazwz/hostc/issues"
	},
	"homepage": "https://github.com/akazwz/hostc/tree/main/packages/client#readme",
	"keywords": [
		"hostc",
		"tunnel",
		"reverse-proxy",
		"cloudflare-workers",
		"sdk"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsup --config tsup.config.ts",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"test": "pnpm -F @hostc/protocol build && tsc -p tsconfig.json && node --test test/*.test.mjs"
	},
	"dependencies": {
		"ws": "^8.20.0"
	},
	"devDependencies": {
		"@hostc/protocol": "workspace:*",
		"@types/node": "^25.6.0",
		"@types/ws": "^8.18.1",
		"tsup": "^8.5.0",
		"typescript": "^6.0.2"
	}
}
