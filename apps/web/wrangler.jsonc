{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "hostc-web",
	"compatibility_date": "2026-05-10",
	"observability": {
		"enabled": true
	},
	"assets": {
		"directory": "build/client",
		"html_handling": "drop-trailing-slash"
	},
	"routes": [
		{
			"pattern": "https://hostc.dev/*",
			"zone_name": "hostc.dev"
		}
	]
}